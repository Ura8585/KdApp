# --- НАСТРОЙКИ БАЗЫ ДАННЫХ POSTGRES ---
# Эти данные Docker использует для создания самой базы
POSTGRES_USER=postgres
POSTGRES_PASSWORD=super_secure_password_123
POSTGRES_DB=kbrddbapp

# --- НАСТРОЙКИ ТВОЕГО C# WEB API ---
ASPNETCORE_ENVIRONMENT=Production

# Строка подключения для Entity Framework (Server должен быть равен имени сервиса базы из docker-compose)
ConnectionStrings__DefaultConnection=Server=postgres-db;Port=5432;Database=kbrddbapp;User Id=postgres;Password=super_secure_password_123;

# Настройки JWT токенов (чтобы не падало с ошибкой ArgumentNullException при генерации токена)
Jwt__Key=TZzGdgtJGBfky99We9hu26lvIgWGi11RrWXK70zo4EW9dXQpmCizY6zwaAieR6wj
Jwt__Issuer=Kdbapp
Jwt__Audience=Kdbapp